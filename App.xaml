<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SkyeShowAndroid.App">

    <Application.Resources>
        <ResourceDictionary>

            <!-- Your existing merged dictionaries -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Theme colors (these get overwritten by ApplyTheme) -->
            <Color x:Key="BackgroundColor">White</Color>
            <Color x:Key="TextColor">Black</Color>
            <Color x:Key="ButtonBackgroundColor">#FF2ED1</Color>
            <Color x:Key="ButtonTextColor">White</Color>

        </ResourceDictionary>
    </Application.Resources>
</Application>