<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:media="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    BackgroundColor="Black"
    NavigationPage.HasNavigationBar="False"
    x:Class="SkyeShowAndroid.FullscreenPage">

    <Grid>

        <media:MediaElement x:Name="Player"
                      Aspect="AspectFit"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill" />

        <!-- Tap anywhere to exit fullscreen -->
        <BoxView BackgroundColor="Transparent">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnExitTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

    </Grid>

</ContentPage>