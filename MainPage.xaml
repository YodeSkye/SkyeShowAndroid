<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:media="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="SkyeShowAndroid.MainPage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{DynamicResource BackgroundColor}">

    <!-- GRID: Top content + bottom button -->
    <Grid RowDefinitions="*,Auto" Padding="20">

        <!-- MAIN CONTENT -->
        <VerticalStackLayout Grid.Row="0" Spacing="20">

            <Button Text="Play Random Video"
                    FontSize="20"
                    BackgroundColor="{DynamicResource ButtonBackgroundColor}"
                    TextColor="{DynamicResource ButtonTextColor}"
                    Clicked="OnPlayClicked"
                    HeightRequest="100" />

            <Border
                StrokeThickness="0"
                BackgroundColor="{DynamicResource BackgroundColor}"
                HeightRequest="300"
                WidthRequest="300"
                HorizontalOptions="Center"
                VerticalOptions="Center">

                <media:MediaElement
                    x:Name="Player"
                    ShouldAutoPlay="False"
                    Aspect="AspectFit"
                    BackgroundColor="Transparent" />
            </Border>

            <Button Text="FullScreen"
                    FontSize="20"
                    BackgroundColor="{DynamicResource ButtonBackgroundColor}"
                    TextColor="{DynamicResource ButtonTextColor}"
                    Clicked="OnFullscreenClicked"
                    HeightRequest="100" />

        </VerticalStackLayout>

        <!-- SETTINGS BUTTON AT THE BOTTOM -->
        <Button Grid.Row="1"
                Text="Settings"
                FontSize="20"
                BackgroundColor="{DynamicResource ButtonBackgroundColor}"
                TextColor="{DynamicResource ButtonTextColor}"
                Clicked="OnSettingsClicked"
                HeightRequest="100" />

    </Grid>

</ContentPage>